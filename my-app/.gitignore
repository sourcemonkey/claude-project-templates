# git で無視するファイルの設定。
# エディタや OS が生成する一時ファイルは、このファイルではなく
# git のグローバル無視設定 (`~/.gitconfig` の `core.excludesfile`) に
# 書くことを推奨。

# bundler の設定ファイル。
/.bundle

# 環境変数ファイル。.env.example はリポジトリに含める。
/.env
/.env.*
!/.env.example

# ログとテンポラリファイル。
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# pid ファイル。ディレクトリ自体は残す。
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Active Storage のローカル保存ファイル(開発・テスト環境)。
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# ビルド成果物(precompile されたアセット、Tailwind のビルド出力、Node モジュール)。
/public/assets
/app/assets/builds/*
!/app/assets/builds/.keep
/node_modules/

# デバッガ(byebug)の履歴。
/.byebug_history

# テストカバレッジレポート。
/coverage/

# credentials の復号鍵。絶対にコミットしない。
/config/master.key
/config/credentials/*.key

# OS が生成するメタデータ。
.DS_Store
